---
import { Picture } from 'astro:assets';
import { services } from '../../data/services';
import Layout from '../../layouts/Layout.astro';
import { serviceProvider, business } from '../../data/business';
import Button from '../../components/atoms/Button.svelte';
import Calendar from '@lucide/astro/icons/calendar';
import ChevronLeft from '@lucide/astro/icons/chevron-left';
import ChevronDown from '@lucide/astro/icons/chevron-down';

export function getStaticPaths() {
    return services.map((service) => ({
        params: { slug: service.slug },
        props: { service }
    }));
}

const { service } = Astro.props;

const schema: Record<string, unknown>[] = [
    {
        '@context': 'https://schema.org',
        '@type': 'Service',
        name: service.title,
        description: service.longDesc,
        url: `${business.url}/tjanster/${service.slug}`,
        provider: serviceProvider,
        areaServed: { '@type': 'City', name: business.address.city },
        ...(service.duration && { offers: { '@type': 'Offer', name: service.title } })
    }
];

if (service.faq && service.faq.length > 0) {
    schema.push({
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: service.faq.map((item) => ({
            '@type': 'Question',
            name: item.q,
            acceptedAnswer: {
                '@type': 'Answer',
                text: item.a
            }
        }))
    });
}
---

<Layout title={`${service.title} – ${business.name}`} description={service.desc} schema={schema}>
    <main class="bg-surface-base">
        <!-- Hero: split layout — text left, image right -->
        <section class="bg-surface-base">
            <div class="mx-auto grid max-w-5xl items-center gap-12 px-6 py-20 md:grid-cols-2">
                <!-- Text side -->
                <div class="flex flex-col justify-center">
                    <a
                        href="/#tjanster"
                        class="inline-flex items-center gap-1.5 text-sm text-text-muted hover:text-text-heading transition-colors duration-300 mb-6">
                        <ChevronLeft class="h-3.5 w-3.5" />
                        Alla tjänster
                    </a>
                    {
                        service.duration && (
                            <p class="mb-5 text-sm font-semibold tracking-widest uppercase text-primary">
                                {service.duration}
                            </p>
                        )
                    }
                    <h1
                        transition:name={service.slug + '-title'}
                        class="text-4xl font-semibold text-text-heading md:text-5xl mb-5">
                        {service.title}
                    </h1>
                    <p class="text-lg text-text-body leading-relaxed mb-8">{service.longDesc}</p>
                    <div>
                        <Button href={import.meta.env.PUBLIC_BOOKING_URL}>
                            <Calendar class="h-5 w-5" aria-hidden="true" />
                            Boka tid
                        </Button>
                    </div>
                </div>

                <!-- Image side -->
                <div class="relative overflow-hidden rounded-3xl aspect-3/4">
                    <Picture
                        src={service.heroImage}
                        alt={service.title}
                        widths={[400, 800, 1200]}
                        sizes="(max-width: 768px) 100vw, 50vw"
                        formats={['avif', 'webp']}
                        class="absolute inset-0 h-full w-full object-cover"
                        loading="eager"
                    />
                </div>
            </div>
        </section>

        <!-- FAQ -->
        {
            service.faq && service.faq.length > 0 && (
                <section class="bg-surface-muted">
                    <div class="mx-auto max-w-3xl px-6 py-16">
                        <h2 class="mb-10 text-2xl font-semibold text-text-heading md:text-3xl">
                            Vanliga frågor
                        </h2>
                        <dl class="space-y-3">
                            {service.faq.map((item) => (
                                <details class="group rounded-2xl border border-card-border bg-card px-6 py-5 open:pb-6">
                                    <summary class="flex cursor-pointer list-none items-center justify-between gap-4 text-base font-medium text-text-heading marker:hidden [&::-webkit-details-marker]:hidden">
                                        {item.q}
                                        <ChevronDown class="h-4 w-4 shrink-0 text-primary transition-transform duration-200 group-open:rotate-180" />
                                    </summary>
                                    <p class="mt-4 text-base leading-relaxed text-text-body">
                                        {item.a}
                                    </p>
                                </details>
                            ))}
                        </dl>
                    </div>
                </section>
            )
        }
    </main>
</Layout>
