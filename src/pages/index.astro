---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/organisms/HeroSection.astro';
import ServicesSection from '../components/organisms/ServicesSection.astro';
import AboutSection from '../components/organisms/AboutSection.astro';
import ContactSection from '../components/organisms/ContactSection.astro';
---

<Layout>
    <HeroSection
        eyebrow="Välkommen"
        title="Helens Fotvård"
        subtitle="Professionell och omtänksam fotvård i en lugn och välkomnande miljö. Vi tar hand om dina fötter med omsorg och erfarenhet."
        ctaHref="#kontakt"
        ctaText="Boka tid"
    />
    <ServicesSection />
    <AboutSection />
    <ContactSection />
</Layout>
