---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/organisms/HeroSection.astro';
import ServicesSection from '../components/organisms/ServicesSection.astro';
import AboutSection from '../components/organisms/AboutSection.astro';
import ContactSection from '../components/organisms/ContactSection.astro';
---

<Layout>
    <HeroSection
        eyebrow="Medicinsk fotvård i Borgholm"
        title="Det naturliga valet för friska fötter på Öland"
        subtitle="Vi erbjuder medicinsk fotvård i Borgholm. Hos oss kan du alltid känna dig välkommen och få sköna fötter."
        ctaHref={import.meta.env.PUBLIC_BOOKING_URL}
        ctaText="Boka tid"
    />
    <ServicesSection />
    <AboutSection />
    <ContactSection />
</Layout>
