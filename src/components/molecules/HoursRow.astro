---
interface Props {
    day: string;
    time: string;
    closed?: boolean;
    bordered?: boolean;
    highlight?: boolean;
}
const { day, time, closed = false, bordered = false, highlight = false } = Astro.props;
---

<div class:list={['flex justify-between gap-4', bordered && 'border-b border-stone-200 pb-3']}>
    <dt>{day}</dt>
    <dd
        class:list={[
            closed ? 'text-stone-400' : '',
            highlight && !closed && 'font-medium text-stone-800'
        ]}>
        {time}
    </dd>
</div>
