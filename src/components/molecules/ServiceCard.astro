---
interface Props {
    title: string;
    desc: string;
    href?: string;
    transitionName?: string;
}
const { title, desc, href, transitionName } = Astro.props;
---

{
    href ? (
        <a
            href={href}
            data-card-link
            class="block bg-card rounded-2xl p-8 border border-card-border hover:border-primary/30 transition-colors duration-300 hover:shadow-md">
            <h3
                data-transition-name={transitionName}
                class="text-xl font-semibold text-text-heading mb-2">
                {title}
            </h3>
            <p class="text-text-body leading-relaxed">{desc}</p>
        </a>
    ) : (
        <div class="bg-card rounded-2xl p-8 border border-card-border transition-colors duration-300">
            <h3 class="text-xl font-semibold text-text-heading mb-2">{title}</h3>
            <p class="text-text-body leading-relaxed">{desc}</p>
        </div>
    )
}

<script>
    document.addEventListener('astro:page-load', () => {
        document.querySelectorAll('[data-card-link]').forEach((link) => {
            link.addEventListener('click', () => {
                const h3 = link.querySelector('[data-transition-name]') as HTMLElement | null;
                if (h3?.dataset.transitionName) {
                    h3.style.viewTransitionName = h3.dataset.transitionName;
                }
            });
        });
    });
</script>
