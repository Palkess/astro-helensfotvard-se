---
interface Props {
    icon: string;
    title: string;
    desc: string;
    href?: string;
}
const { icon, title, desc, href } = Astro.props;
---

{
    href ? (
        <a
            href={href}
            class="block bg-blue-50 rounded-2xl p-8 border border-stone-100 hover:border-stone-200 transition-colors hover:shadow-sm">
            <div class="text-3xl mb-4">{icon}</div>
            <h3 class="text-xl font-semibold text-stone-900 mb-3">{title}</h3>
            <p class="text-stone-600 leading-relaxed">{desc}</p>
        </a>
    ) : (
        <div class="bg-blue-50 rounded-2xl p-8 border border-stone-100 hover:border-stone-200 transition-colors">
            <div class="text-3xl mb-4">{icon}</div>
            <h3 class="text-xl font-semibold text-stone-900 mb-3">{title}</h3>
            <p class="text-stone-600 leading-relaxed">{desc}</p>
        </div>
    )
}
