---
interface Props {
    icon: string;
    title: string;
    desc: string;
    href?: string;
}
const { icon, title, desc, href } = Astro.props;
---

{
    href ? (
        <a
            href={href}
            class="block bg-card rounded-2xl p-8 border border-card-border hover:border-primary/30 transition-colors duration-300 hover:shadow-md">
            <div class="w-12 h-12 bg-primary-light rounded-xl flex items-center justify-center mb-5">
                <span class="text-2xl">{icon}</span>
            </div>
            <h3 class="text-xl font-semibold text-text-heading mb-3">{title}</h3>
            <p class="text-text-body leading-relaxed">{desc}</p>
        </a>
    ) : (
        <div class="bg-card rounded-2xl p-8 border border-card-border transition-colors duration-300">
            <div class="w-12 h-12 bg-primary-light rounded-xl flex items-center justify-center mb-5">
                <span class="text-2xl">{icon}</span>
            </div>
            <h3 class="text-xl font-semibold text-text-heading mb-3">{title}</h3>
            <p class="text-text-body leading-relaxed">{desc}</p>
        </div>
    )
}
