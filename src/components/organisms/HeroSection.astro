---
import Button from '../atoms/Button.svelte';

interface Props {
    eyebrow: string;
    title: string;
    subtitle: string;
    ctaHref: string;
    ctaText: string;
}
const { eyebrow, title, subtitle, ctaHref, ctaText } = Astro.props;
---

<section class="bg-blue-50 py-28 px-6 text-center">
    <div class="max-w-3xl mx-auto">
        <p class="text-blue-800 font-medium text-lg mb-4 tracking-wide uppercase">{eyebrow}</p>
        <h1 class="text-5xl md:text-6xl font-semibold text-stone-900 mb-6 leading-tight">
            {title}
        </h1>
        <p class="text-xl text-stone-600 mb-10 leading-relaxed max-w-xl mx-auto">
            {subtitle}
        </p>
        <Button href={ctaHref}>{ctaText}</Button>
    </div>
</section>
