---
import { Picture } from 'astro:assets';
import heroImage from '../../assets/images/helen.jpg';
import { CalendarIcon } from 'lucide-svelte';

interface Props {
    eyebrow: string;
    title: string;
    subtitle: string;
    ctaHref: string;
    ctaText: string;
}
const { eyebrow, title, subtitle, ctaHref, ctaText } = Astro.props;
---

<section class="bg-surface-base">
    <div class="mx-auto grid max-w-5xl items-center gap-12 px-6 py-20 md:grid-cols-2">
        <!-- Text column -->
        <div>
            <p class="mb-5 text-sm font-semibold tracking-widest uppercase text-primary">
                {eyebrow}
            </p>
            <h1 class="mb-6 text-4xl font-semibold text-text-heading md:text-5xl lg:text-6xl">
                {title}
            </h1>
            <p class="mb-10 max-w-lg text-lg text-text-body">
                {subtitle}
            </p>
            <a
                href={ctaHref}
                class="inline-flex items-center gap-2 rounded-full bg-primary px-8 py-4 text-base font-medium text-white shadow-sm transition-colors duration-300 hover:bg-primary-dark focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary">
                <CalendarIcon class="h-5 w-5" aria-hidden="true" />
                {ctaText}
            </a>
        </div>

        <!-- Image column -->
        <div class="relative">
            <div class="relative overflow-hidden rounded-3xl aspect-3/4">
                <Picture
                    src={heroImage}
                    alt="Medicinsk fotvård hos Helens Fotvård"
                    widths={[600, 900, 1200]}
                    sizes="(max-width: 768px) 100vw, 50vw"
                    formats={['avif', 'webp']}
                    class="absolute inset-0 h-full w-full object-cover"
                    loading="eager"
                />
            </div>
            <!-- Name badge -->
            <div
                class="absolute bottom-4 right-4 flex items-center gap-2 rounded-full bg-white/90 px-4 py-2.5 backdrop-blur-sm">
                <span class="text-sm font-semibold text-primary">Helen Andersson</span>
                <span class="text-sm">Leg. medicinsk fotvårdare</span>
            </div>
        </div>
    </div>

    <!-- Contact strip -->
    <div class="border-t border-card-border">
        <div class="mx-auto grid max-w-5xl gap-6 px-6 py-8 md:grid-cols-3">
            <div class="flex items-center gap-3">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6 shrink-0 text-primary"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                    aria-hidden="true">
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z">
                    </path>
                </svg>
                <div>
                    <a
                        href="tel:+46767676725"
                        class="block text-sm font-medium text-primary transition-colors duration-300 hover:text-primary-dark">
                        076-76 76 725
                    </a>
                    <p class="text-xs text-text-muted">Ring för att boka tid</p>
                </div>
            </div>

            <div class="flex items-center gap-3">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6 shrink-0 text-primary"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                    aria-hidden="true">
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z">
                    </path>
                </svg>
                <div>
                    <a
                        href="mailto:helen@helensfotvard.se"
                        class="block text-sm font-medium text-primary transition-colors duration-300 hover:text-primary-dark">
                        helen@helensfotvard.se
                    </a>
                    <p class="text-xs text-text-muted">Svarar inom ett par dagar</p>
                </div>
            </div>

            <div class="flex items-center gap-3">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-6 w-6 shrink-0 text-primary"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                    aria-hidden="true">
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                    </path>
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z">
                    </path>
                </svg>
                <div>
                    <p class="text-sm font-medium text-primary">Trädgårdsgatan 14, Borgholm</p>
                    <p class="text-xs text-text-muted">Borgholm, Öland</p>
                </div>
            </div>
        </div>
    </div>
</section>
