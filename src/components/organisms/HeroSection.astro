---
import { Picture } from 'astro:assets';
import heroImage from '../../assets/images/helen.jpg';
import Calendar from '@lucide/astro/icons/calendar';
import Phone from '@lucide/astro/icons/phone';
import Mail from '@lucide/astro/icons/mail';
import MapPin from '@lucide/astro/icons/map-pin';
import { business } from '../../data/business';

interface Props {
    eyebrow: string;
    title: string;
    subtitle: string;
    ctaHref: string;
    ctaText: string;
}
const { eyebrow, title, subtitle, ctaHref, ctaText } = Astro.props;
---

<section class="bg-surface-base">
    <div
        class="mx-auto grid max-w-5xl items-center gap-12 px-6 pt-20 pb-10 md:pb-20 md:grid-cols-2">
        <!-- Text column -->
        <div>
            <p class="mb-5 text-sm font-semibold tracking-widest uppercase text-primary">
                {eyebrow}
            </p>
            <h1 class="mb-6 text-4xl font-semibold text-text-heading md:text-5xl lg:text-6xl">
                {title}
            </h1>
            <p class="mb-10 max-w-lg text-lg text-text-body">
                {subtitle}
            </p>
            <a
                href={ctaHref}
                class="inline-flex items-center gap-2 rounded-full bg-primary px-8 py-4 text-base font-medium text-white shadow-sm transition-colors duration-300 hover:bg-primary-dark focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary">
                <Calendar class="h-5 w-5" />
                {ctaText}
            </a>
        </div>

        <!-- Image column -->
        <div class="relative @container">
            <div class="relative overflow-hidden rounded-3xl aspect-3/4">
                <Picture
                    src={heroImage}
                    alt="Medicinsk fotvård hos Helens Fotvård"
                    widths={[600, 900, 1200]}
                    sizes="(max-width: 768px) 100vw, 50vw"
                    formats={['avif', 'webp']}
                    class="absolute inset-0 h-full w-full object-cover"
                    loading="eager"
                    fetchpriority="high"
                />
            </div>
            <!-- Name badge -->
            <div
                class="absolute bottom-4 right-4 ml-4 flex flex-wrap justify-center @xs:justify-baseline items-center gap-2 rounded-full bg-white/90 px-4 py-2.5 backdrop-blur-sm">
                <span class="text-sm font-semibold text-primary">{business.owner.name}</span>
                <span class="text-sm">{business.owner.title}</span>
            </div>
        </div>
    </div>

    <!-- Contact strip -->
    <div class="border-t border-card-border">
        <div class="mx-auto grid max-w-5xl gap-6 px-6 py-8 md:grid-cols-3">
            <div class="flex items-center gap-3">
                <Phone class="h-6 w-6 shrink-0 text-primary" />
                <div>
                    <a
                        href={`tel:${business.contact.phoneRaw}`}
                        class="block font-medium text-primary transition-colors duration-300 hover:text-primary-dark">
                        {business.contact.phoneDisplay}
                    </a>
                    <p class="text-sm text-text-muted">Ring för att boka tid</p>
                </div>
            </div>

            <div class="flex items-center gap-3">
                <Mail class="h-6 w-6 shrink-0 text-primary" />
                <div>
                    <a
                        href={`mailto:${business.contact.emailHelen}`}
                        class="block font-medium text-primary transition-colors duration-300 hover:text-primary-dark">
                        {business.contact.emailHelen}
                    </a>
                    <p class="text-sm text-text-muted">Svarar inom ett par dagar</p>
                </div>
            </div>

            <div class="flex items-center gap-3">
                <MapPin class="h-6 w-6 shrink-0 text-primary" />
                <div>
                    <p class="text-sm font-medium text-primary">
                        {business.address.street}, {business.address.city}
                    </p>
                    <p class="text-sm text-text-muted">{business.address.city}, Öland</p>
                </div>
            </div>
        </div>
    </div>
</section>
