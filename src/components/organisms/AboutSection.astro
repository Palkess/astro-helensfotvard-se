---
import { Picture } from 'astro:assets';
import aboutImage1 from '../../assets/images/helen-och-jenny.jpg';
import aboutImage2 from '../../assets/images/utanfor-helens-fotvard.jpg';
---

<section id="om-oss" class="py-24 px-6 bg-surface-base">
    <div class="max-w-5xl mx-auto space-y-24">
        <!-- Block 1: image left, text right -->
        <div class="grid md:grid-cols-2 gap-12 items-center">
            <div class="relative overflow-hidden rounded-2xl aspect-4/3">
                <Picture
                    src={aboutImage1}
                    alt="Medicinsk fotvård hos Helens Fotvård"
                    widths={[400, 800]}
                    sizes="(max-width: 768px) 100vw, 50vw"
                    formats={['avif', 'webp']}
                    class="absolute inset-0 h-full w-full object-cover"
                    loading="lazy"
                />
            </div>
            <div>
                <h2 class="text-3xl font-semibold text-text-heading mb-6">
                    Vi hjälper dig med friska och välmående fötter
                </h2>
                <p class="text-text-body leading-relaxed mb-4">
                    Helens Fotvård grundades den 9 augusti 2009 av Helen Andersson. Sedan februari
                    2015 finns vi på Trädgårdsgatan 14 i Borgholm, dit Jenny Andersson tillkom som
                    utbildad fotvårdare.
                </p>
                <p class="text-text-body leading-relaxed">
                    Tillsammans strävar vi efter att vara det naturliga förstahandsvalet för
                    medicinsk fotvård på Öland — med professionell och omtänksam vård grundad i
                    vetenskapligt beprövade metoder.
                </p>
            </div>
        </div>

        <!-- Block 2: text left, image right -->
        <div class="grid md:grid-cols-2 gap-12 items-center">
            <div>
                <h2 class="text-3xl font-semibold text-text-heading mb-6">
                    Professionell fotvård med personlig omtanke
                </h2>
                <p class="text-text-body leading-relaxed mb-4">
                    Helen utbildade sig till medicinsk fotvårdsspecialist vid Axelsons Gymnasiska
                    Institut i Malmö 1999 och har sedan dess kontinuerligt vidareutbildat sig inom
                    fotterapi och olika fotåkommor.
                </p>
                <p class="text-text-body leading-relaxed">
                    Jenny anslöt till kliniken 2015 och bidrar med kompetens och engagemang som gör
                    att varje patient får bästa möjliga behandling. Båda är medlemmar i Sveriges
                    Fotterapeuter och följer förbundets etiska riktlinjer.
                </p>
            </div>
            <div class="relative overflow-hidden rounded-2xl aspect-4/3">
                <Picture
                    src={aboutImage2}
                    alt="Fotvård med friskvård hos Helens Fotvård"
                    widths={[400, 800]}
                    sizes="(max-width: 768px) 100vw, 50vw"
                    formats={['avif', 'webp']}
                    class="absolute inset-0 h-full w-full object-cover"
                    loading="lazy"
                />
            </div>
        </div>
    </div>
</section>
