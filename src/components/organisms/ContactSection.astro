---
import SectionHeader from '../molecules/SectionHeader.astro';
import ContactItem from '../molecules/ContactItem.astro';
import { business } from '../../data/business';
---

<section id="kontakt" class="py-24 px-6 bg-surface-muted">
    <div class="max-w-5xl mx-auto">
        <SectionHeader
            title="Kontakt & bokning"
            subtitle="Ring oss för att boka en tid. Avbokning och ändringar görs via telefon – inte via e-post."
        />

        <div class="grid md:grid-cols-2 gap-10">
            <div class="bg-card rounded-2xl p-10 border border-card-border">
                <h3 class="text-2xl font-semibold text-text-heading mb-6">Kontaktuppgifter</h3>
                <dl class="space-y-5 text-lg">
                    <ContactItem
                        label="Telefon"
                        value={business.contact.phoneDisplay}
                        href={`tel:${business.contact.phoneRaw}`}
                    />
                    <ContactItem
                        label="Helen"
                        value={business.contact.emailHelen}
                        href={`mailto:${business.contact.emailHelen}`}
                    />
                    <ContactItem
                        label="Jenny"
                        value={business.contact.emailJenny}
                        href={`mailto:${business.contact.emailJenny}`}
                    />
                    <div>
                        <dt class="font-medium text-text-heading">Adress</dt>
                        <dd class="text-text-body mt-1">
                            {business.address.street}<br />{business.address.postalCode}
                            {business.address.city}
                        </dd>
                    </div>
                </dl>
            </div>

            <div class="bg-card rounded-2xl p-10 border border-card-border">
                <h3 class="text-2xl font-semibold text-text-heading mb-4">Öppettider</h3>
                <p class="text-text-body leading-relaxed mb-6">
                    Öppettiderna varierar från vecka till vecka. Aktuella tider hittar du på vår
                    Facebook-sida eller genom att ringa oss.
                </p>
                <a
                    href={business.contact.facebook}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 rounded-lg border border-card-border bg-surface-base px-5 py-3 text-text-heading transition-colors duration-300 hover:border-primary/30 hover:text-primary">
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        class="h-5 w-5 text-blue-600"
                        viewBox="0 0 24 24"
                        fill="currentColor">
                        <path
                            d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z">
                        </path>
                    </svg>
                    Se aktuella öppettider på Facebook
                </a>

                <div
                    class="mt-6 rounded-lg border border-notice-border bg-notice-bg px-4 py-3 text-sm text-notice-text">
                    Avbokning och ändringar görs via telefon eller personligt besök – inte via
                    e-post.
                </div>
            </div>
        </div>
    </div>
</section>
