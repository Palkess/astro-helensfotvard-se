---
import { services } from '../../data/services';
import SectionHeader from '../molecules/SectionHeader.astro';
import ServiceCard from '../molecules/ServiceCard.astro';
---

<section id="tjanster" class="py-24 px-6 bg-surface-muted">
    <div class="max-w-5xl mx-auto">
        <SectionHeader
            title="Våra tjänster"
            subtitle="Vi erbjuder ett brett utbud av behandlingar för dina fötter."
        />
        <div class="grid md:grid-cols-2 gap-6">
            {
                services.map((s) => (
                    <ServiceCard
                        title={s.title}
                        desc={s.desc}
                        href={'/tjanster/' + s.slug}
                        transitionName={s.slug + '-title'}
                    />
                ))
            }
        </div>
    </div>
</section>
