---
import { ClientRouter } from 'astro:transitions';
import Footer from '../components/organisms/Footer.astro';
import Header from '../components/organisms/Header.svelte';
import CookieConsent from '../components/organisms/CookieConsent.svelte';
import '../styles/global.css';
import { business } from '../data/business';

interface Props {
    title?: string;
    description?: string;
    schema?: Record<string, unknown> | Record<string, unknown>[];
}

const {
    title = `${business.name} – Medicinsk fotvård i Borgholm`,
    description = 'Helens Fotvård – medicinsk fotvård i Borgholm på Öland. Vi erbjuder medicinsk fotvård, fotvård med friskvård, nagelklippning och behandling av nageltrång. Det naturliga valet för friska fötter på Öland.',
    schema
} = Astro.props;
---

<!doctype html>
<html lang="sv">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={description} />
        <meta name="robots" content="noindex, nofollow" />
        <title>{title}</title>
        {
            schema && (
                <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
            )
        }
        <ClientRouter />
    </head>
    <body>
        <Header client:load transition:persist />
        <slot />
        <Footer />
        <CookieConsent client:load />
    </body>
</html>
