---
import Footer from '../components/organisms/Footer.astro';
import Header from '../components/organisms/Header.svelte';
import CookieConsent from '../components/organisms/CookieConsent.svelte';
import '../styles/global.css';
---

<!doctype html>
<html lang="sv">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
            rel="stylesheet"
        />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />
        <meta
            name="description"
            content="Helens Fotvård – medicinsk fotvård i Borgholm på Öland. Vi erbjuder medicinsk fotvård, fotvård med friskvård, nagelklippning och behandling av nageltrång. Det naturliga valet för friska fötter på Öland."
        />
        <meta name="robots" content="noindex, nofollow" />
        <title>Helens Fotvård – Medicinsk fotvård i Borgholm</title>
    </head>
    <body>
        <Header client:load />
        <slot />
        <Footer />
        <CookieConsent client:load />
    </body>
</html>
